[Unit]
Description=GopherClaw Gateway — AI agent gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/gopherclaw
Restart=always
RestartSec=5
Environment=HOME=%h

# Logging to journal
StandardOutput=journal
StandardError=journal
SyslogIdentifier=gopherclaw

[Install]
WantedBy=default.target
